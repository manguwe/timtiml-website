{
  "version": 2,
  "builds": [
    { "src": "api/**/*.py", "use": "@vercel/python" },
    { "src": "*.html",      "use": "@vercel/static" },
    { "src": "*.{png,jpg,jpeg,gif,svg,ico,css,js}", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat",         "dest": "/api/chat.py" },
    { "src": "/api/users",        "dest": "/api/users.py" },
    { "src": "/api/progress",     "dest": "/api/progress.py" },
    { "src": "/api/testimonials", "dest": "/api/testimonials.py" },
    { "src": "/api/payments",     "dest": "/api/payments.py" },
    { "src": "/(.*\\.html)",      "dest": "/$1" },
    { "src": "/",                 "dest": "/index.html" },
    { "src": "/(.*)",             "dest": "/$1" }
  ]
}
